/*                KEY POSITIONS

  ╭──────────────╮ ╭──────────────╮
  │ LT4 LT3 LT2 LT1 LT0 │ │ RT0 RT1 RT2 RT3 RT4 │
  │ LM4 LM3 LM2 LM1 LM0 │ │ RM0 RM1 RM2 RM3 RM4 │
  │ LB4 LB3 LB2 LB1 LB0 │ │ RB0 RB1 RB2 RB3 RB4 │
  ╰────╮     LH1 LH0 │ │ RH0 RH1     ╭────╯
          ╰────────╯ ╰───╯ */

#define COMBO_TERM_FAST 50
#define COMBO_TERM_SLOW 30

#define COMBO_IDLE_FAST 150
#define COMBO_IDLE_SLOW 50

/**
 * Temporarily switches to a layer (`&mo`) while a modifier is held.
 * Analogous to QMK's `LM()`, using a parameterized macro.
 *
 * Params:
 *  Layer to switch to
 *
 * Example:
 *  `&lm NUM_LAYER `
 */
#define MODMO(NAME, MOD) \
/ { \
  macros { \
  NAME: NAME { \
      compatible = "zmk,behavior-macro-one-param"; \
      wait-ms = <0>; \
      tap-ms = <0>; \
      #binding-cells = <1>; \
      bindings \
        = <&macro_param_1to1> \
        , <&macro_press &mo MACRO_PLACEHOLDER> \
        , <&macro_press &kp MOD> \
        , <&macro_pause_for_release> \
        , <&macro_release &kp MOD> \
        , <&macro_param_1to1> \
        , <&macro_release &mo MACRO_PLACEHOLDER> \
        ; \
    }; \
  }; \
};

MODMO(mos, LSHIFT)
MODMO(moa, LALT)
MODMO(moc, LCTRL)

#define MAKE_HRML(NAME, HOLD, TAP, TRIGGER_POS)                                 \
  ZMK_HOLD_TAP(NAME, bindings = <HOLD>, <TAP>; flavor = "hold-preferred";            \
               tapping-term-ms = <280>; quick-tap-ms = <QUICK_TAP_MS>;         \
               require-prior-idle-ms = <150>; hold-trigger-on-release;         \
               hold-trigger-key-positions = <TRIGGER_POS>;)

MAKE_HRML(molc, &moc, &kp, KEYS_R THUMBS) // Left-hand HRMs.
MAKE_HRML(mola, &moa, &kp, KEYS_R THUMBS) // Right-hand HRMs.
MAKE_HRML(mols, &mos, &kp, KEYS_R THUMBS) // Right-hand HRMs.
MAKE_HRML(mora, &moa, &kp, KEYS_L THUMBS) // Left-hand HRMs.
MAKE_HRML(morc, &moc, &kp, KEYS_L THUMBS) // Right-hand HRMs.
MAKE_HRML(mors, &mos, &kp, KEYS_L THUMBS) // Right-hand HRMs.


// Numbers
ZMK_COMBO(one,   &kp N1, LT4 LT3        , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(three, &kp N3,     LT3 LT2    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(five,  &kp N5,         LT2 LT1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(two,   &mols ARIGHT N2, LM4 LM3       , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(four,  &kp   N4       ,        LB2 LB1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(six,   &kp N6, RT1 RT2        , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(eight, &kp N8,     RT2 RT3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(zero,  &kp N0,         RT3 RT4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(nine,  &mors ALEFT N9,          RM3 RM4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(seven, &kp N7         , RB1 RB2        , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Fn keys
ZMK_COMBO(f1,  &kp F1, LT4 LT3        , ALEFT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f3,  &kp F3,     LT3 LT2    , ALEFT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f5,  &kp F5,         LT2 LT1, ALEFT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(f2,  &kp F2, LM4 LM3        , ALEFT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f4,  &kp F4,         LB2 LB1, ALEFT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(f6,  &kp F6, RT1 RT2        , ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f8,  &kp F8,     RT2 RT3    , ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f10, &kp F10,        RT3 RT4, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(f9,  &kp F9,         RM3 RM4, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f7,  &kp F7, RB1 RB2        , ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)


// Left top
ZMK_COMBO(grave, &kp GRAVE,     LT4     LT2, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(pgdn,  &kp PAGE_DOWN, LT4         LT1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(t,     &kp T,         LT3     LT1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Left middle
ZMK_COMBO(tabl,   &hml LA(LCTRL) TAB,                 LM2 LM1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escl,   &mola ARIGHT   ESC,             LM3 LM2    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(caps,   &hml  LS(LALT) &caps_word, LM4      LM2    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(left,   &hml LS(LCTRL) LEFT,       LM4         LM1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(g,      &molc ARIGHT   G,               LM3     LM1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Left bottom
ZMK_COMBO(end,    &kp END,       LB3 LB2   , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(home,   &kp HOME,  LB4 LB3       , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(leader, &leader,   LB4    LB2    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(down ,  &kp DOWN,  LB4        LB1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(b,      &kp B,         LB3    LB1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)


// Right top
ZMK_COMBO(blash, &kp BACKSLASH,     RT2    RT4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(pgup,  &kp PAGE_UP  , RT1        RT4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(y,     &kp Y,         RT1    RT3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Right middle
ZMK_COMBO(retr,   &hmr LC(LALT)   RET,   RM1 RM2        , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escr,   &mora ALEFT     ESC,       RM2 RM3    , BASE , COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(sqt,    &hmr LA(LSHIFT) SQT,      RM2     RM4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(right,  &hmr LS(LCTRL)  RIGHT, RM1         RM4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(h,      &morc ALEFT     H,     RM1     RM3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(f11,    &kp F11,   RM1 RM2        , ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f12,    &kp F12,       RM2 RM3    , ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Right bottom
ZMK_COMBO(minus, &kp MINUS,     RB2 RB3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(equal, &kp EQUAL,         RB3 RB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(rbkt,  &kp RBKT,      RB2     RB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(up,    &kp UP ,   RB1         RB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(n,     &kp N,     RB1     RB3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Settings impossible combo
ZMK_COMBO(settingsl, &to SETTINGS, LT4 LT0 LB0, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(settingsr, &to SETTINGS, RT4 RT0 RB0, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)


// Reverse

// Right top
ZMK_COMBO(grave, &kp GRAVE,     RT4     RT2, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(pgdn,  &kp PAGE_DOWN, RT4         RT1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(t,     &kp T,         RT3     RT1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Right middle
ZMK_COMBO(tabl,   &hml LA(LCTRL) TAB,                 RM2 RM1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escl,   &mola ARIGHT   ESC,             RM3 RM2    , RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(caps,   &hml  LS(LALT) &caps_word, RM4      RM2    , RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(left,   &hml LS(LCTRL) LEFT,       RM4         RM1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(g,      &molc ARIGHT   G,               RM3     RM1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Right bottom
ZMK_COMBO(end,    &kp END,       RB3 RB2   , RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(home,   &kp HOME,  RB4 RB3       , RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(leader, &leader,   RB4    RB2    , RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(down ,  &kp DOWN,  RB4        RB1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(b,      &kp B,         RB3    RB1, RRIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)




// Left top
ZMK_COMBO(blash, &kp BACKSLASH,     LT2    LT4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(pgup,  &kp PAGE_UP  , LT1        LT4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(y,     &kp Y,         LT1    LT3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Left middle
ZMK_COMBO(retr,   &hmr LC(LALT)   RET,   LM1 LM2        , BASE, COMBO_TELM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escr,   &mora ALEFT     ESC,       LM2 LM3    , BASE , COMBO_TELM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(sqt,    &hmr LA(LSHIFT) SQT,      LM2     LM4, BASE, COMBO_TELM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(right,  &hmr LS(LCTRL)  RIGHT, LM1         LM4, BASE, COMBO_TELM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(h,      &morc ALEFT     H,     LM1     LM3    , BASE, COMBO_TELM_FAST, COMBO_IDLE_FAST)

// Left bottom
ZMK_COMBO(minus, &kp MINUS,     LB2 LB3    , BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(equal, &kp EQUAL,         LB3 LB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(rbkt,  &kp LBKT,      LB2     LB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(up,    &kp UP ,   LB1         LB4, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
