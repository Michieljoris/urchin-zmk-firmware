/*                KEY POSITIONS

  ╭──────────────╮ ╭──────────────╮
  │ LT4 LT3 LT2 LT1 LT0 │ │ RT0 RT1 RT2 RT3 RT4 │
  │ LM4 LM3 LM2 LM1 LM0 │ │ RM0 RM1 RM2 RM3 RM4 │
  │ LB4 LB3 LB2 LB1 LB0 │ │ RB0 RB1 RB2 RB3 RB4 │
  ╰────╮     LH1 LH0 │ │ RH0 RH1     ╭────╯
          ╰────────╯ ╰───╯ */

#define COMBO_TERM_FAST 50
#define COMBO_TERM_SLOW 30

#define COMBO_IDLE_FAST 150
#define COMBO_IDLE_SLOW 50

/**
 * Temporarily switches to a layer (`&mo`) while a modifier is held.
 * Analogous to QMK's `LM()`, using a parameterized macro.
 *
 * Params:
 *  Layer to switch to
 *
 * Example:
 *  `&lm NUM_LAYER `
 */
/ {
  macros {

  lmc: lmc {
      compatible = "zmk,behavior-macro-one-param";
      wait-ms = <0>;
      tap-ms = <0>;
      #binding-cells = <1>;
      bindings
        = <&macro_param_1to1>
        , <&macro_press &mo MACRO_PLACEHOLDER>
        , <&macro_press &kp LCTRL>
        , <&macro_pause_for_release>
        , <&macro_release &kp LCTRL>
        , <&macro_param_1to1>
        , <&macro_release &mo MACRO_PLACEHOLDER>
        ;
    };
  lma: lma {
      compatible = "zmk,behavior-macro-one-param";
      wait-ms = <0>;
      tap-ms = <0>;
      #binding-cells = <1>;
      bindings
        = <&macro_param_1to1>
        , <&macro_press &mo MACRO_PLACEHOLDER>
        , <&macro_press &kp LALT>
        , <&macro_pause_for_release>
        , <&macro_release &kp LALT>
        , <&macro_param_1to1>
        , <&macro_release &mo MACRO_PLACEHOLDER>
        ;
    };

  };
  };

#define MAKE_HRML(NAME, HOLD, TAP, TRIGGER_POS)                                 \
  ZMK_HOLD_TAP(NAME, bindings = <HOLD>, <TAP>; flavor = "hold-preferred";            \
               tapping-term-ms = <280>; quick-tap-ms = <QUICK_TAP_MS>;         \
               require-prior-idle-ms = <150>; hold-trigger-on-release;         \
               hold-trigger-key-positions = <TRIGGER_POS>;)

MAKE_HRML(molc, &lmc, &kp, KEYS_R THUMBS) // Left-hand HRMs.
MAKE_HRML(mola, &lma, &kp, KEYS_R THUMBS) // Right-hand HRMs.
MAKE_HRML(mora, &lma, &kp, KEYS_L THUMBS) // Left-hand HRMs.
MAKE_HRML(morc, &lmc, &kp, KEYS_L THUMBS) // Right-hand HRMs.

// Numbers
ZMK_COMBO(one,   &kp N1, LT4 LT3, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(two,   &kp N2, LT4 LT1, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(three, &kp N3, LT3 LT2, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(four,  &kp N4, RT1 RT4, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(five,  &kp N5, LT2 LT1, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(six,   &kp N6, RT1 RT2, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(seven, &kp N7, LB4 LB1, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(eight, &kp N8, RT2 RT3, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(nine,  &kp N9, RB1 RB4, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(zero,  &kp N0, RT3 RT4, BASE  BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Fn keys
ZMK_COMBO(f1,  &kp F1, LT4 LT3, ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f2,  &kp F2, LT4 LT1, ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f3,  &kp F3, LT3 LT2, ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f4,  &kp F4, RT1 RT4, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f5,  &kp F5, LT2 LT1, ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f6,  &kp F9, RB1 RB4, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f7,  &kp F6, RT1 RT2, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f8,  &kp F7, LB4 LB1, ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f9,  &kp F8, RT2 RT3, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f10, &kp F10, RT3 RT4, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)


// Various combos
ZMK_COMBO(escl,   &mola ARIGHT  ESC, LM3 LM2, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(tabl,   &hml LC(LALT) TAB, LM2 LM1, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(retr,   &hmr LC(LALT) RET, RM1 RM2, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escr,   &mora ALEFT   ESC, RM2 RM3, BASE , COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escr,   &mora ALEFTL   ESC, RM2 RM3, BASEL, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(escr,   &mora ALEFTM   ESC, RM2 RM3, BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)

ZMK_COMBO(f11,  &kp F11, RM1 RM2, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(f12,  &kp F12, RM2 RM3, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Leave the index finger alone !!!
// Left
ZMK_COMBO(t, &kp T, LT3 LT1, BASE BASEM ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(g, &molc ARIGHT G, LM3 LM1, BASE BASEM ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(b, &kp B, LB3 LB1, BASE BASEM ALEFT ALEFTL ALEFTM, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Right
ZMK_COMBO(y,     &kp Y,     RT3 RT1, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(grave, &kp GRAVE, RT3 RT1, ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)


ZMK_COMBO(h, &morc ALEFT H, RM3 RM1, BASE, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(hl, &morc ALEFTL H, RM3 RM1, BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
/* ZMK_COMBO(hm, &morc ALEFTM H, RM3 RM1, BASEL, COMBO_TERM_FAST, COMBO_IDLE_FAST) */

ZMK_COMBO(n, &kp N, RB3 RB1, BASE BASEM ARIGHT, COMBO_TERM_FAST, COMBO_IDLE_FAST)

// Both space keys for settings
ZMK_COMBO(settingsl, &to SETTINGS, LH1 LH0, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
ZMK_COMBO(settingsr, &to SETTINGS, RH0 RH1, BASE BASEM, COMBO_TERM_FAST, COMBO_IDLE_FAST)
