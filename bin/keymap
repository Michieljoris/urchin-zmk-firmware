set -e

#https://github.com/caksoylar/keymap-drawer
#pipx install keymap-drawer

rm -f urchin_keymap.yaml
rm -f urchin_keymap.ortho.svg
uvx --from keymap-drawer keymap parse -c 10 -z config/urchin.keymap >urchin_keymap.yaml
uvx --from keymap-drawer keymap draw urchin_keymap.yaml >urchin_keymap.ortho.svg
