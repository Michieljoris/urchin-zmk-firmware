set -e

COMMIT_COUNT=$(git rev-list --count HEAD)
DSHIELD="urchin_left nice_view_adapter nice_view"
DIR=$(pwd)
VIEW=/Users/michiel/opt/nice-view-gem
VIEW=""
LEADER=$(realpath ../zmk-leader-key)
UNICODE=$(realpath ../zmk-unicode)
EXTRA_MODULES="$DIR;$LEADER;$UNICODE;$VIEW"
BUILD_DIR=$DIR/firmware/$COMMIT_COUNT
BUILD_DIR_LATEST=$DIR/firmware/latest
ZMK=$HOME/opt/zmk/
mkdir -p $BUILD_DIR
mkdir -p $BUILD_DIR_LATEST
(cd $ZMK
 source .venv/bin/activate
 cd app
 west build -b nice_nano@2.0.0//zmk -d build/left --pristine=auto -- -DSHIELD=$SHIELD -DZMK_EXTRA_MODULES=$EXTRA_MODULES
 west build -b nice_nano@2.0.0//zmk  -d build/right --pristine=auto -- -DSHIELD=$SHIELD -DZMK_EXTRA_MODULES=$EXTRA_MODULES

 cp  build/left/zephyr/zmk.uf2 $BUILD_DIR/left.uf2
 cp  build/left/zephyr/zmk.uf2 $BUILD_DIR_LATEST/left.uf2
 cp  build/right/zephyr/zmk.uf2 $BUILD_DIR/right.uf2
 cp  build/right/zephyr/zmk.uf2 $BUILD_DIR_LATEST/right.uf2
)

echo "Copied left.uf2 and right.uf2 to $BUILD_DIR and $BUILD_DIR_LATEST"
